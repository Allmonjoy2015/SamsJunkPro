{
  "name": "samsjunkpro",
  "version": "1.0.0",
  "description": "Scrapyard management desktop app built with Electron",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest --testPathPattern=tests/ --no-coverage",
    "build": "electron-builder"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "jest": "^29.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  }
}
